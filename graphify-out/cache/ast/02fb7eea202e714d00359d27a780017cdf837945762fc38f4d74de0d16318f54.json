est(datePart)) {\n            const [y, m, d] = datePart.split(\"-\").map((p) => Number.parseInt(p, 10));\n            if (![y, m, d].every(Number.isFinite)) return null;\n            return new Date(y, m - 1, d);\n        }\n\n        let match = datePart.match(/^(\\d{2})\\.(\\d{2})\\.(\\d{4})$/);\n        if (match) {\n            const [, dd, mm, yyyy] = match;\n            const day = Number.parseInt(dd, 10);\n            const month = Number.parseInt(mm, 10);\n            const year = Number.parseInt(yyyy, 10);\n            if (![day, month, year].every(Number.isFinite)) return null;\n            return new Date(year, month - 1, day);\n        }\n\n        match = datePart.match(/^(\\d{2})\\/(\\d{2})\\/(\\d{4})$/);\n        if (match) {\n            const [, dd, mm, yyyy] = match;\n            const day = Number.parseInt(dd, 10);\n            const month = Number.parseInt(mm, 10);\n            const year = Number.parseInt(yyyy, 10);\n            if (![day, month, year].every(Number.isFinite)) return null;\n            return new Date(year, month - 1, day);\n        }\n\n        const asDate = new Date(datePart);\n        if (Number.isNaN(asDate.getTime())) return null;\n        return asDate;\n    })", "is_member_call": false, "source_file": "C:\\All work project\\IPBL\\api\\admin\\server-lib\\calendar-normalize.ts", "source_location": "L118"}, {"caller_nid": "server_lib_calendar_normalize_istrulyliverow", "callee": "getTime", "is_member_call": true, "source_file": "C:\\All work project\\IPBL\\api\\admin\\server-lib\\calendar-normalize.ts", "source_location": "L156"}, {"caller_nid": "server_lib_calendar_normalize_istrulyliverow", "callee": "getFullYear", "is_member_call": true, "source_file": "C:\\All work project\\IPBL\\api\\admin\\server-lib\\calendar-normalize.ts", "source_location": "L156"}, {"caller_nid": "server_lib_calendar_normalize_istrulyliverow", "callee": "getMonth", "is_member_call": true, "source_file": "C:\\All work project\\IPBL\\api\\admin\\ser