{
  "name": "ipbl-minimal-viewer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node ./node_modules/vite/bin/vite.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:vercel": "npm run build && vercel deploy --prod --yes",
    "backfill:results": "node scripts/backfill-results.mjs",
    "verify:h2h": "node scripts/verify-h2h-drawer.mjs",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.0",
    "@vercel/node": "^5.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.5",
    "playwright": "^1.50.0",
    "typescript": "~5.7.2",
    "vercel": "^50.39.0",
    "vite": "^6.0.5",
    "vitest": "^4.1.5"
  }
}
