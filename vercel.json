{
  "version": 2,
  "framework": "vite",
  "rewrites": [
    { "source": "/api/results/live", "destination": "/api/results/live.ts" },
    { "source": "/api/results", "destination": "/api/results.ts" },
    { "source": "/api/admin/backfill-results", "destination": "/api/admin/backfill-results.ts" },
    { "source": "/api/backtest", "destination": "/api/backtest.ts" },
    { "source": "/api/gen-analysis", "destination": "/api/gen-analysis.ts" },
    { "source": "/api/cron/sync-results", "destination": "/api/cron/cron-sync-results.ts" },
    { "source": "/api/cron/record-live", "destination": "/api/cron/record-live.ts" },
    { "source": "/api/ipbl/(.*)", "destination": "https://api.ipbl.pro/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}